                          "type":  "multiple_choice",
                          "prompt":  "What is a trade-off?",
                          "choices":  [
                                          {
                                              "id":  "A",
                                              "text":  "All the alternatives given up when a choice is made",
                                              "is_correct":  true,
                                              "feedback":  "Correct. A trade-off includes the options given up when one alternative is chosen."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "A reward for making a good economic decision",
                                              "is_correct":  false,
                                              "feedback":  "A reward is an incentive, not a trade-off."
                                          },
                                          {
                                              "id":  "C",
                                              "text":  "The money spent on a purchase",
                                              "is_correct":  false,
                                              "feedback":  "Spending money can be part of a decision, but a trade-off is about alternatives given up."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "A decision made by the government",
                                              "is_correct":  false,
                                              "feedback":  "A trade-off can occur in any decision, not just government decisions."
                                          }
                                      ]
                      },
                      {
                          "question_id":  "ECON-U01-L02-QUIZ-002",
                          "type":  "true_false",
                          "prompt":  "Opportunity cost is the value of the next best alternative that is not chosen.",
                          "choices":  [
                                          {
