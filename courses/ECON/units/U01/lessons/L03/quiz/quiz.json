                                          },
                                          {
                                              "id":  "B",
                                              "text":  "People buy and sell goods mainly through private competition",
                                              "is_correct":  false,
                                              "feedback":  "That example describes a market economy."
                                          },
                                          {
                                              "id":  "C",
                                              "text":  "Families continue jobs and production methods passed down over generations",
                                              "is_correct":  true,
                                              "feedback":  "Correct. Traditional economies rely on customs and long-standing practices."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "The economy combines private business with government services and regulation",
                                              "is_correct":  false,
                                              "feedback":  "That example describes a mixed economy."
                                          }
                                      ]
                      },
                      {
