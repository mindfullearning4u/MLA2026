                          "question_id":  "ECON-U01-L03-QUIZ-001",
                          "type":  "multiple_choice",
                          "prompt":  "What is an economic system?",
                          "choices":  [
                                          {
                                              "id":  "A",
                                              "text":  "A method a society uses to decide what to produce, how to produce it, and for whom to produce it",
                                              "is_correct":  true,
                                              "feedback":  "Correct. An economic system answers the major economic questions of production and distribution."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "A process used only to count profits and losses",
                                              "is_correct":  false,
                                              "feedback":  "An economic system is broader than profit and loss. It organizes production, distribution, and decision-making."
                                          },
                                          {
                                              "id":  "C",
                                              "text":  "A list of needs and wants for each family",
                                              "is_correct":  false,
                                              "feedback":  "Needs and wants are part of economics, but they do not define an economic system."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "A type of incentive used by businesses only",
                                              "is_correct":  false,
                                              "feedback":  "An economic system is not an incentive. It is the structure used to organize economic decisions."
                                          }
                                      ]
                      },
                      {
                          "question_id":  "ECON-U01-L03-QUIZ-002",
                          "type":  "true_false",
                          "prompt":  "In a command economy, the government makes many major decisions about production and prices.",
                          "choices":  [
                                          {
                                              "id":  "A",
                                              "text":  "False",
                                              "is_correct":  false,
                                              "feedback":  "This statement is true for a command economy."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "True",
                                              "is_correct":  true,
                                              "feedback":  "Correct. In a command economy, the government directs major economic decisions."
                                          }
                                      ]
                      },
                      {
