                                              "is_correct":  false,
                                              "feedback":  "Opportunity cost is not all options, only the next best one."
                                          },
                                          {
                                              "id":  "C",
                                              "text":  "The value of the trip the student gave up",
                                              "is_correct":  true,
                                              "feedback":  "Correct. Opportunity cost is the value of the next best alternative not chosen."
