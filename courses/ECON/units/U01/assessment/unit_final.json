                                          {
                                              "id":  "C",
                                              "text":  "A student has enough time to do everything they want",
                                              "is_correct":  false,
                                              "feedback":  "If time were unlimited, scarcity would not exist."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "A company produces more goods than people want",
                                              "is_correct":  false,
                                              "feedback":  "This reflects surplus, not scarcity."
                                          }
