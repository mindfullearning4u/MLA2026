                          "type":  "multiple_choice",
                          "prompt":  "Which situation best demonstrates scarcity?",
                          "choices":  [
                                          {
                                              "id":  "A",
                                              "text":  "A city must choose between building a school or a hospital due to limited funds",
                                              "is_correct":  true,
                                              "feedback":  "Correct. Limited resources require choices, which is the definition of scarcity."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "A store has unlimited products available at all times",
                                              "is_correct":  false,
                                              "feedback":  "Scarcity exists when resources are limited, not unlimited."
