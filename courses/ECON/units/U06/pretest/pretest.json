                                          {
                                              "id":  "A",
                                              "text":  "Government control of all production",
                                              "is_correct":  false,
                                              "feedback":  "Comparative advantage is not about government control."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "Higher population size",
                                              "is_correct":  false,
                                              "feedback":  "Population size does not define comparative advantage."
                                          },
                                          {
                                              "id":  "C",
                                              "text":  "Lower opportunity cost",
                                              "is_correct":  true,
                                              "feedback":  "Correct. Comparative advantage depends on producing something at a lower opportunity cost."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "Avoiding all international trade",
                                              "is_correct":  false,
                                              "feedback":  "Comparative advantage helps explain why trade can be beneficial."
                                          }
                                      ]
                      },
                      {
