                                          {
                                              "id":  "A",
                                              "text":  "A good or service bought from another country",
                                              "is_correct":  true,
                                              "feedback":  "Correct. An import is a good or service purchased from another country."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "A good or service sold to another country",
                                              "is_correct":  false,
                                              "feedback":  "That describes an export, not an import."
                                          },
                                          {
                                              "id":  "C",
                                              "text":  "A tax placed on international trade",
                                              "is_correct":  false,
                                              "feedback":  "An import is a product or service bought from abroad, not a tax."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "A product produced only for local use",
                                              "is_correct":  false,
                                              "feedback":  "This does not describe an import."
