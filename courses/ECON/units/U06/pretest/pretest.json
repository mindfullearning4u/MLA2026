                                          {
                                              "id":  "A",
                                              "text":  "Because trade removes all scarcity",
                                              "is_correct":  false,
                                              "feedback":  "Trade can help countries, but it does not remove scarcity."
                                          },
                                          {
                                              "id":  "B",
