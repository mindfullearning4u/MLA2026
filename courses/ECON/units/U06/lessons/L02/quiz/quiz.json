                          "choices":  [
                                          {
                                              "id":  "A",
                                              "text":  "True",
                                              "is_correct":  true,
                                              "feedback":  "Correct. Comparative advantage depends on lower opportunity cost, not simply greater total output."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "False",
                                              "is_correct":  false,
                                              "feedback":  "This statement is true because comparative advantage focuses on opportunity cost."
