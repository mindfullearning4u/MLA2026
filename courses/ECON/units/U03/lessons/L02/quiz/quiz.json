                          "type":  "true_false",
                          "prompt":  "A labor market is the system in which workers look for jobs and employers look for workers.",
                          "choices":  [
                                          {
                                              "id":  "A",
                                              "text":  "True",
                                              "is_correct":  true,
                                              "feedback":  "Correct. A labor market connects people offering their labor with employers seeking workers."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "False",
                                              "is_correct":  false,
                                              "feedback":  "This is incorrect. Labor markets involve the relationship between workers and employers."
