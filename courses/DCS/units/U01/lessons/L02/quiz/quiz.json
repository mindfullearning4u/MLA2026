                          "type":  "multiple_choice",
                          "prompt":  "Which action best supports digital equity?",
                          "choices":  [
                                          {
                                              "id":  "A",
                                              "text":  "Allowing access only to experienced users",
                                              "is_correct":  false,
                                              "feedback":  "Equity supports all users, not just experienced ones."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "Providing equal access to devices and internet resources",
                                              "is_correct":  true,
                                              "feedback":  "Correct. Digital equity ensures fair access for all users."
                                          },
                                          {
                                              "id":  "C",
                                              "text":  "Ignoring gaps in access",
                                              "is_correct":  false,
                                              "feedback":  "Addressing gaps is essential for equity."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "Focusing only on high-end technology",
                                              "is_correct":  false,
                                              "feedback":  "Equity is about access, not device quality."
