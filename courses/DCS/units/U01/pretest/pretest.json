                          "question_id":  "DCS-U01-PRETEST-Q01",
                          "type":  "multiple_choice",
                          "prompt":  "Which statement best describes digital citizenship?",
                          "choices":  [
                                          {
                                              "id":  "A",
                                              "text":  "Using the internet only for school-related tasks",
                                              "is_correct":  false,
                                              "feedback":  "Digital citizenship applies to all online behavior, not just school use."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "Participating safely, responsibly, and respectfully in digital spaces",
                                              "is_correct":  true,
                                              "feedback":  "Correct. This captures the core definition of digital citizenship."
                                          },
                                          {
                                              "id":  "C",
                                              "text":  "Avoiding all online interaction to prevent problems",
                                              "is_correct":  false,
                                              "feedback":  "The goal is responsible participation, not avoidance."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "Following rules only when monitored online",
                                              "is_correct":  false,
                                              "feedback":  "Digital citizenship requires consistent responsible behavior."
                                          }
                                      ]
                      },
                      {
