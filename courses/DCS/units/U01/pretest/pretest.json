                                          {
                                              "id":  "C",
                                              "text":  "The difference between online and offline communication",
                                              "is_correct":  false,
                                              "feedback":  "This is not related to access inequality."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "The gap between those who have reliable access to technology and those who do not",
                                              "is_correct":  true,
                                              "feedback":  "Correct. This defines the digital divide accurately."
                                          }
                                      ]
                      },
