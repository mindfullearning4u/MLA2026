                                              "feedback":  "This still spreads harm."
                                          },
                                          {
                                              "id":  "B",
                                              "text":  "Ignore the message completely",
                                              "is_correct":  false,
                                              "feedback":  "Ignoring may allow harm to continue."
                                          },
                                          {
                                              "id":  "C",
                                              "text":  "Refuse to share and report the situation if necessary",
                                              "is_correct":  true,
                                              "feedback":  "Correct. This reflects responsible and ethical behavior."
                                          },
                                          {
                                              "id":  "D",
                                              "text":  "Ask others what they think before acting",
                                              "is_correct":  false,
                                              "feedback":  "Responsibility should not depend on peer approval."
